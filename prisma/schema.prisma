generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agency {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  logo         String?
  primaryColor String?   @default("#0070f3")
  contactEmail String?
  phone        String?
  address      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sellers      Seller[]
  cars         Car[]
  inquiries    Inquiry[]
}

model Seller {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
}

model Car {
  id          String    @id @default(cuid())
  make        String
  model       String
  year        Int
  price       Float
  mileage     Int       @default(0)
  description String?
  images      String    @default("[]")
  status      String    @default("available")
  agencyId    String
  agency      Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  inquiries   Inquiry[]

  @@index([agencyId])
}

model Inquiry {
  id           String   @id @default(cuid())
  customerName String
  email        String
  phone        String?
  message      String
  status       String   @default("unread")
  carId        String
  car          Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  agencyId     String
  agency       Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([agencyId])
  @@index([carId])
}
